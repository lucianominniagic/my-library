{
  "name": "scripta-manent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typeorm": "node --require ./node_modules/tsx/dist/cjs/index.cjs ./node_modules/typeorm/cli.js -d src/server/db/data-source.ts",
    "db:migrate": "npm run typeorm -- migration:run",
    "db:migrate:revert": "npm run typeorm -- migration:revert",
    "db:migration:generate": "npm run typeorm -- migration:generate",
    "db:migration:create": "npm run typeorm -- migration:create",
    "db:migration:show": "npm run typeorm -- migration:show",
    "db:schema:log": "npm run typeorm -- schema:log",
    "db:schema:drop": "npm run typeorm -- schema:drop",
    "db:query": "npm run typeorm -- query",
    "seed:user": "node --require ./node_modules/tsx/dist/cjs/index.cjs src/scripts/seed-user.ts",
    "import:csv": "node --require ./node_modules/tsx/dist/cjs/index.cjs src/scripts/import-csv.ts",
    "import:csv:dry": "node --require ./node_modules/tsx/dist/cjs/index.cjs src/scripts/import-csv.ts --dry-run --verbose",
    "update:title-en": "node --require ./node_modules/tsx/dist/cjs/index.cjs src/scripts/update-title-en.ts",
    "update:title-en:dry": "node --require ./node_modules/tsx/dist/cjs/index.cjs src/scripts/update-title-en.ts --dry-run --verbose",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  },
  "dependencies": {
    "@auth/typeorm-adapter": "^2.11.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/x-data-grid": "^9.1.0",
    "@mui/x-date-pickers": "^9.1.0",
    "@tanstack/react-query": "^5.100.9",
    "@trpc/client": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.2.1",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.29",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "server-only": "^0.0.1",
    "tsx": "^4.21.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5"
  }
}
