# =============================================================================
# Database — PostgreSQL
# Crea il DB con: createdb scripta_manent
# oppure: psql -c "CREATE DATABASE scripta_manent;"
# =============================================================================
DB_HOST=localhost           # default: localhost
DB_PORT=5432                # default: 5432
DB_USER=your-db-username    # obbligatorio
DB_PASSWORD=your-db-password # obbligatorio
DB_NAME=scripta_manent      # obbligatorio

# =============================================================================
# Autenticazione — NextAuth v5
# Genera NEXTAUTH_SECRET con: openssl rand -base64 32
# =============================================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# =============================================================================
# Admin — utente iniziale creato da seed-user.ts
# =============================================================================
ADMIN_EMAIL=your-admin@example.com  # obbligatorio
ADMIN_PASSWORD=your-secure-password  # obbligatorio
ADMIN_NAME=Luciano                   # opzionale, default: 'Luciano'
